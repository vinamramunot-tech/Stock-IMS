{
  "name": "mava-gems-stock",
  "version": "4.2.0",
  "description": "Premium, secure desktop stock management for jewelry inventory.",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "build:mac-silicon": "tauri build --target aarch64-apple-darwin",
    "build:mac-universal": "tauri build --target universal-apple-darwin",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:all": "npm run build:mac-universal && npm run build:windows",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build",
    "ios:init": "tauri ios init",
    "ios:dev": "bash scripts/ios-dev.sh",
    "ios:dev:device": "tauri ios dev",
    "ios:build": "tauri ios build",
    "release": "bash scripts/release.sh",
    "tauri": "tauri"
  },
  "keywords": [
    "jewelry",
    "inventory",
    "stock",
    "security",
    "tauri",
    "desktop"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
