{
  "name": "mava-gems-stock",
  "version": "10.2.0",
  "description": "Premium, secure desktop stock management for jewelry inventory.",
  "scripts": {
    "predev": "node scripts/sync-version.js",
    "dev": "tauri dev",
    "prebuild": "node scripts/sync-version.js",
    "build": "tauri build",
    "prebuild:mac-intel": "node scripts/sync-version.js",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "prebuild:mac-silicon": "node scripts/sync-version.js",
    "build:mac-silicon": "tauri build --target aarch64-apple-darwin",
    "prebuild:mac-universal": "node scripts/sync-version.js",
    "build:mac-universal": "tauri build --target universal-apple-darwin",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:all": "npm run build:mac-universal && npm run build:windows",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "preandroid:build": "node scripts/sync-version.js",
    "android:build": "tauri android build",
    "android:build:signed": "npm run android:build -- --apk && ./scripts/sign-android.sh",
    "ios:init": "tauri ios init",
    "ios:dev": "bash scripts/ios-dev.sh",
    "ios:dev:device": "tauri ios dev",
    "preios:build": "node scripts/sync-version.js",
    "ios:build": "tauri ios build",
    "release": "bash scripts/release.sh",
    "version": "node scripts/sync-version.js && cargo check --manifest-path src-tauri/Cargo.toml && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock",
    "tauri": "tauri"
  },
  "keywords": [
    "jewelry",
    "inventory",
    "stock",
    "security",
    "tauri",
    "desktop"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "firebase": "^12.14.0",
    "jspdf": "^4.2.1"
  }
}
