{
  "name": "mava-gems-stock",
  "version": "1.0.0",
  "description": "Premium, secure desktop stock management for jewelry inventory.",
  "scripts": {
    "dev": "source $HOME/.cargo/env && tauri dev",
    "build": "source $HOME/.cargo/env && tauri build",
    "build:mac-intel": "source $HOME/.cargo/env && tauri build --target x86_64-apple-darwin",
    "build:mac-silicon": "source $HOME/.cargo/env && tauri build --target aarch64-apple-darwin",
    "build:mac-universal": "source $HOME/.cargo/env && tauri build --target universal-apple-darwin",
    "build:windows": "source $HOME/.cargo/env && tauri build --target x86_64-pc-windows-msvc",
    "build:all": "npm run build:mac-universal && npm run build:windows",
    "android:init": "source $HOME/.cargo/env && tauri android init",
    "android:dev": "source $HOME/.cargo/env && tauri android dev",
    "android:build": "source $HOME/.cargo/env && tauri android build",
    "ios:init": "source $HOME/.cargo/env && tauri ios init",
    "ios:dev": "source $HOME/.cargo/env && tauri ios dev",
    "ios:build": "source $HOME/.cargo/env && tauri ios build",
    "tauri": "source $HOME/.cargo/env && tauri"
  },
  "keywords": [
    "jewelry",
    "inventory",
    "stock",
    "security",
    "tauri",
    "desktop"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
