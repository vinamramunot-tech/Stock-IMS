# Mava Gems Stock Management Git Ignore

# Private Business Database (DO NOT COMMIT SENSITIVE STOCK DATA)
DATA/
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.tmp
*.bak

# Persistent Local Machine Configuration
app_config.json

# Node dependencies
node_modules/

# Rust / Cargo build outputs
src-tauri/target/
src-tauri/gen/

# Compiled Desktop App Distribution Installers & Packages
dist/
out/
release/
*.zip
*.dmg
*.pkg
*.app
*.exe
*.msi
*.deb
*.rpm

# Environment variables (sensitive info)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System / OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Android Signing Keys & Keystores (SENSITIVE)
*.keystore
*.jks
keystore.properties
*.b64

